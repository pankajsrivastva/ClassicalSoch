@{
    ViewData["Title"] = "FAQ";
}

<section class="py-5">
    <div class="container">
        <div class="section-heading text-center mb-5">
            <p class="eyebrow">Frequently Asked Questions</p>
            <h2 class="fw-bold">Everything you need to know before your visit</h2>
        </div>
        <div class="accordion" id="faqAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header"><button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#faq1">Do you offer bridal makeup?</button></h2>
                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion"><div class="accordion-body">Yes, our bridal beauticians offer premium makeup and styling packages for special occasions.</div></div>
            </div>
            <div class="accordion-item">
                <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#faq2">Can I book an academy course?</button></h2>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion"><div class="accordion-body">Absolutely. You can apply for our professional beauty courses directly through our contact form or by calling the salon.</div></div>
            </div>
        </div>
    </div>
</section>
