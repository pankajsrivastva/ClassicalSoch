@{
    ViewData["Title"] = "Academy Courses";
}

<section class="py-5">
    <div class="container">
        <div class="section-heading text-center mb-5">
            <p class="eyebrow">Professional Academy</p>
            <h2 class="fw-bold">Upskill with industry-led beauty education</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card service-card h-100">
                    <img src="~/Images/BeautyCourse.png" class="card-img-top" alt="Course" />
                    <div class="card-body">
                        <h4 class="card-title">Professional Makeup Course</h4>
                        <p class="text-muted">Duration: 3 months</p>
                        <p>Learn bridal, fashion, and editorial makeup with guided practical training.</p>
                        <p><strong>Fees:</strong> ₹18,000</p>
                        <a class="btn btn-gold" href="/Home/Contact">Apply Now</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card service-card h-100">
                    <img src="~/Images/HairCourse.png" class="card-img-top" alt="Course" />
                    <div class="card-body">
                        <h4 class="card-title">Hair Styling & Coloring Course</h4>
                        <p class="text-muted">Duration: 4 months</p>
                        <p>Master haircutting, coloration, and professional salon techniques.</p>
                        <p><strong>Fees:</strong> ₹22,000</p>
                        <a class="btn btn-gold" href="/Home/Contact">Apply Now</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
